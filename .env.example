# Copy to .env and fill in. Loaded by scripts via python-dotenv if present.

# Hugging Face token (needed to download gated Nemotron models/datasets).
HF_TOKEN=

# Optional: cache locations to keep large downloads off the home volume.
HF_HOME=./.hf_cache
TRANSFORMERS_CACHE=./.hf_cache

# Optional: pin a single GPU.
CUDA_VISIBLE_DEVICES=0
